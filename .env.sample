# Modèle des secrets / variables du déploiement « Zero Touch ».
#
# CE FICHIER EST LA LISTE CANONIQUE DES GITHUB SECRETS.
# Chaque ligne ci-dessous (sauf REACT_APP_API_URL, voir plus bas) = un secret à
# créer dans : Settings > Secrets and variables > Actions > New repository secret.
# Source de vérité des noms : docs/CONVENTIONS.md §5.
#
# AUCUNE valeur réelle ici : uniquement des placeholders.
# /!\ Ne JAMAIS committer vos clés AWS ni aucun secret réel.
#
# Légende valeur : [figé] = valeur imposée · [choisi] = vous décidez ·
#                  [généré] = sortez une valeur aléatoire forte (commandes en bas).

# === AWS — credentials de l'IAM user CI (least-privilege) ===
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_DEFAULT_REGION=eu-west-3                       # [figé] région imposée par le sujet

# === Registre Docker privé (EC2 #1, déjà provisionnée) ===
# REGISTRY_HOST = IP publique du registre + port HTTPS (Nginx). Format : <IP>:443
REGISTRY_HOST=REGISTRY_PUBLIC_IP:443              # [choisi] dépend de l'EC2 #1
REGISTRY_USERNAME=admin                           # [choisi] login docker du registre
REGISTRY_PASSWORD=change-me                       # [généré] mot de passe fort

# === Application — base de données MySQL ===
MYSQL_ROOT_PASSWORD=change-me                     # [généré] mot de passe fort
MYSQL_DATABASE=ynov_ci                            # [figé] nom de la base applicative

# === Application — backend FastAPI ===
ADMIN_EMAIL=admin@example.com                     # [choisi] compte admin initial
ADMIN_PASSWORD=change-me                          # [généré] mot de passe fort
JWT_SECRET=change-me-with-a-long-random-string    # [généré] clé de signature des tokens

# === Frontend (build CRA) — N'EST PAS UN SECRET ===
# URL de l'API vue par le navigateur. Variable de BUILD pour CRA (cf. issue #8),
# PAS un GitHub Secret : le pipeline la calcule depuis l'IP publique de l'EC2 app
# (output Terraform instance_public_ip). Laissée ici pour mémoire/contrat.
REACT_APP_API_URL=http://APP_PUBLIC_IP:8000

# -----------------------------------------------------------------------------
# Générer les valeurs [généré] (32 octets en base64) :
#   openssl rand -base64 32
# Créer un secret depuis la CLI GitHub (exemple) :
#   gh secret set JWT_SECRET --body "$(openssl rand -base64 32)"
# -----------------------------------------------------------------------------
