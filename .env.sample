# Modèle des secrets / variables nécessaires au déploiement « Zero Touch ».
# À configurer en GitHub Secrets (Settings > Secrets and variables > Actions).
# AUCUNE valeur réelle ici : uniquement des placeholders.
# /!\ Ne JAMAIS committer vos clés AWS.

# === AWS (pour Terraform) ===
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_DEFAULT_REGION=eu-west-3

# === Registre Docker privé (EC2 #1) ===
# IP publique du registre + identifiants de connexion (login docker).
REGISTRY_HOST=REGISTRY_PUBLIC_IP:443
REGISTRY_USERNAME=admin
REGISTRY_PASSWORD=change-me

# === Application — base de données MySQL ===
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=ynov_ci

# === Application — backend FastAPI ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-with-a-long-random-string

# === Application — frontend (build CRA) ===
# URL de l'API vue par le navigateur. ATTENTION : variable de BUILD pour CRA
# (cf. issue #8). Vaut l'IP publique de l'EC2 applicative au déploiement.
REACT_APP_API_URL=http://APP_PUBLIC_IP:8000
